# ─────────────────────────────────────────────────────────────
# EduAdapt — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Supabase (https://supabase.com/dashboard) — Auth + Database + file storage
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx
# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxx
# Name of the Supabase Storage bucket used for uploads + generated PDFs
SUPABASE_STORAGE_BUCKET=eduadapt-documents

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App URL — used to build invite links (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
